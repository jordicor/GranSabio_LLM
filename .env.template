# Gran Sabio LLM Engine - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your API keys

# Required API Keys for AI Services
# =================================

# OpenAI API Key (for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (for Claude models)  
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# Google AI API Key (for Gemini models)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-api-key-here

# xAI API Key (for Grok models)
# Get from: https://console.x.ai/
XAI_API_KEY=xai-your-xai-key-here

# OpenRouter API Key (for additional hosted models)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# MiniMax API Key (for MiniMax M-series models)
# Get from: https://platform.minimax.io/
MINIMAX_API_KEY=your-minimax-api-key-here

# Moonshot/Kimi API Key (for Kimi models)
# Get from: https://platform.kimi.ai/console/api-keys
MOONSHOT_API_KEY=your-moonshot-api-key-here

# Attachment Storage
# ==================
# Required for attachment functionality. Use any random string.
# This pepper is used to hash usernames for storage paths.
PEPPER=your-random-secret-pepper-here

# Optional Configuration
# =====================

# FastAPI Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Request Limits
MAX_CONCURRENT_REQUESTS=10
OLLAMA_HOST=http://localhost:11434
OLLAMA_MAX_CONCURRENT_REQUESTS=1
REQUEST_TIMEOUT=12000
REQUEST_TIMEOUTS_DEFAULT_PATH=request_timeouts.default.json
# Optional local override file. This file is ignored by git so each deployment can tune waits.
REQUEST_TIMEOUTS_PATH=request_timeouts.json
MAX_RETRIES=5
RETRY_DELAY=15.0
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_MAX_DELAY=120.0
RETRY_JITTER=true

# External generation token floor (optional)
# Protects public /generate requests from very small max_tokens values.
# Per-model entries accept "model:min_tokens" pairs separated by commas.
EXTERNAL_GENERATION_MIN_TOKENS_ENABLED=true
EXTERNAL_GENERATION_MIN_TOKENS_REASONING=4096
# EXTERNAL_GENERATION_MIN_TOKENS_DEFAULT=4096
# EXTERNAL_GENERATION_MIN_TOKENS_MODELS=gpt-5.5:4096,gpt-5.4:4096

# Session Management
MAX_ACTIVE_SESSIONS=100
SESSION_TIMEOUT=3600
SESSION_CLEANUP_INTERVAL=300
SESSION_CLEANUP_IDLE_EMPTY_CHECKS=3
SESSION_CLEANUP_IDLE_INTERVAL=3600
# CLEANUP_INTERVAL is still accepted as a legacy alias for SESSION_CLEANUP_INTERVAL

# Logging
LOG_LEVEL=INFO
VERBOSE_MAX_ENTRIES=100

# Runtime model routing
# Model defaults live in this JSON file, not in config.py or model_specs.json.
LLM_ROUTING_DEFAULT_PATH=llm_routing.default.json

# Quality Standards (optional)
DEFAULT_MIN_GLOBAL_SCORE=8.0
DEFAULT_MAX_ITERATIONS=5

# Smart Edit Configuration (optional)
# Maximum paragraphs that can be edited in a single smart edit iteration
MAX_PARAGRAPHS_PER_INCREMENTAL_RUN=12

# Maximum consecutive smart edit iterations before forcing full regeneration
DEFAULT_MAX_CONSECUTIVE_SMART_EDITS=10

# Evidence Grounding model routing lives in llm_routing.default.json
# under evidence.extract_claims and evidence.score_logprobs.
